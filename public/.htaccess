# Vite SPA on Hostinger (LiteSpeed / Apache)

# Route everything that isn't a real file/dir to index.html.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Files under /assets/ are content-hashed by Vite: the filename changes
  # whenever the content does, so they can be cached forever.
  SetEnvIf Request_URI "^/assets/" HASHED
  Header set Cache-Control "public, max-age=31536000, immutable" env=HASHED

  # Everything else — index.html, fonts, images — keeps a
  # stable name across deploys, so it must be revalidated. "no-cache" still
  # allows storage; the browser just sends a conditional request and gets a
  # cheap 304 when unchanged. This is what stops stale index.html from
  # pointing at deleted /assets/ hashes after a deploy.
  Header set Cache-Control "no-cache" env=!HASHED
</IfModule>
